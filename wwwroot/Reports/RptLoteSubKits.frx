using System.Globalization;

namespace FastReport
{
  public class ReportScript
  {
  
  public string CalcularQtde()
  {
   string codigoStr = Report.GetColumnValue(&quot;TB_ESTRUTURA_SUB_KIT_LOTE.CODIGO_ITEM_FILHO&quot;).ToString();
   string qtdeStr = Report.GetColumnValue(&quot;TB_ESTRUTURA_SUB_KIT_LOTE.QTDE&quot;).ToString();

   double qtde;
   if (!double.TryParse(qtdeStr.Replace(&quot;,&quot;, &quot;.&quot;), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out qtde))
    return &quot;0&quot;;

   double resultado;

   if (codigoStr == &quot;33412&quot;)
    resultado = qtde / 0.000324;
   else if (codigoStr == &quot;33413&quot;)
    resultado = qtde / 0.00059;
   else
    resultado = qtde;

   if (codigoStr == &quot;33412&quot; || codigoStr == &quot;33413&quot;)
    return ((int)Math.Round(resultado)).ToString(); // retorna inteiro
   else
    return resultado.ToString(&quot;0.0000&quot;); // retorna com 4 decimais
  }
  }
}
</ScriptText>
