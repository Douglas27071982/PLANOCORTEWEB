        ===============================================================-->
<script src="https://cdn.datatables.net/fixedheader/3.2.2/js/dataTables.fixedHeader.min.js"></script>


<!-- ============================================================
        =LIBRERIAS PARA EXPORTAR A ARCHIVOS
        ===============================================================-->
<script src="https://cdn.datatables.net/buttons/2.0.0/js/dataTables.buttons.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.html5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.0.0/js/buttons.print.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/0.4.1/html2canvas.min.js"></script>

<script>



    function executeSaveImageFunction() {
        const contentToSave = document.getElementById('chapa');
        const codigochapa = document.getElementById('txtcodchapa').value;
        const codigomaquina = document.getElementById('txtcodmaquina').value;

        const aproveitamento = document.getElementById('txtaproveitamento').value;
        const m3peças = document.getElementById('txtm3peças').value;
        const totalpeças = document.getElementById('txttotalpeças').value;





        if (contentToSave) {
            // Usando a versão antiga com 'onrendered' ao invés de '.then()'
            html2canvas(contentToSave, {
                onrendered: function (canvas) {
                    // Aqui você pode tratar o canvas gerado
                    var dataURL = canvas.toDataURL('image/png');
                    console.log(dataURL); // Exibe o base64 da imagem

                    SalvarDados();
                    saveImage(dataURL, codigochapa, codigomaquina, aproveitamento, m3peças, totalpeças);  // Passando codigomaquina para a função saveImage
                    // Passa os dados para a função de salvar os tipos, comprimentos e quantidades

                }

            });
        } else {
            console.error('Elemento não encontrado: #chapa');
        }


    }


    // Função para salvar a imagem no servidor
    function saveImage(base64Image, codigochapa, codigomaquina, aproveitamento, m3peças, totalpeças) {
        fetch('@Url.Action("SaveImage", "PlanoCorte")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ image: base64Image, codigochapa: codigochapa, codigomaquina: codigomaquina, aproveitamento: aproveitamento, m3peças: m3peças, totalpeças: totalpeças })
        })
            .then(response => response.json())
            .then(data => {

                Swal.fire({
                    title: 'Atenção, é necessario informar no check todos os retalhos do plano, tem certeza que selecionou todos?',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    confirmButtonText: 'Sim, Salvar',
                    cancelButtonText: 'Voltar'
                }).then((result) => {

                    if (result.isConfirmed) {



                        window.location.href = '/PlanoCorte/CadastroPlanoCorte'; // Redireciona após salvar


                    }

                })










            })
            .catch(error => {
                console.error('Erro ao salvar imagem:', error);
            });
    }

    function SalvarDados() {
        operacion = "crear";

        jQuery.ajax({
            url: '@Url.Action("Limpar", "PlanoCorte")',
            type: "DELETE",
            dataType: "json",
            contentType: "application/json; charset=utf-8",
            success: function (data) {
                console.log(data)
                if (data.respuesta) {
                    tabla.ajax.reload();
                }
            },
            error: function (error) {
            },
            beforeSend: function () {
            }
        });


        // Cria arrays para armazenar os dados apenas dos campos preenchidos
        var tipos = [];
        var comprimentos = [];
        var qtdes = [];

        // Percorre os 20 campos txttipo, txtcomprimento e txtqtde
        for (var i = 1; i <= 20; i++) {
            var tipo = $("#txttipo" + i).val();
            var comprimento = $("#txtcomprimento" + i).val();
            var qtde = $("#txtqtde" + i).val();

            // Verifica se o campo não está vazio antes de adicionar
            if (tipo.trim() !== "") {
                tipos.push(tipo);
            }

            if (comprimento.trim() !== "") {
                comprimentos.push(comprimento);
            }

            if (qtde.trim() !== "") {
                qtdes.push(qtde);
            }
        }

        // Se pelo menos um campo foi preenchido, envia a requisição AJAX
        if (tipos.length > 0 || comprimentos.length > 0 || qtdes.length > 0) {
            jQuery.ajax({
                url: '@Url.Action("SalvarDados", "PlanoCorte")',
                type: "POST",
                headers: {
                    operacion: operacion
                },
                data: {
                    Tipos: tipos.join(','),            // Envia os dados como uma string separada por vírgulas
                    Medidas: comprimentos.join(','),
                    Qtdes: qtdes.join(',')
                },
                dataType: "json",
                success: function (data) {
                    console.log(data)



                },
                error: function (error) {
                    console.log(error);
                },
                beforeSend: function () {
                }
            });
        } else {
            Swal.fire({
                title: 'Nenhum dado foi preenchido',
                text: 'Fechando...',
                icon: 'warning',
                timer: 1500,
                buttons: false,
            });
        }
    }




    var v_larg = 0;
