    function ContarPecas() {
        var totalRetangulos = document.querySelectorAll(".peça").length; // Conta todos os elementos com a classe "peça"
        $("#txttotalpeças").val(totalRetangulos); // Atualiza o campo com o total de retângulos
    }


    function CalcularAreaTotal() {
        var totalM2 = 0;

        // Seleciona todos os elementos com a classe "peça"
        document.querySelectorAll(".peça").forEach(function (retangulo) {
            // Obtém as dimensões do retângulo a partir do texto dentro do <span>
            var texto = retangulo.innerText.trim();
            var dimensoes = texto.split("X"); // Divide o texto "larguraXcomprimento"

            if (dimensoes.length === 2) {
                var largura = parseFloat(dimensoes[0]) / 1000; // Converte para metros
                var comprimento = parseFloat(dimensoes[1]) / 1000; // Converte para metros

                if (!isNaN(largura) && !isNaN(comprimento)) {
                    totalM2 += largura * comprimento; // Soma a área do retângulo
                }
            }
        });

        // Atualiza o campo de entrada com o valor total calculado
        $("#txtm2peças").val(totalM2.toFixed(4)); // Armazena o valor com 4 casas decimais
    }

    function CalcularVolumeTotal() {
        var totalM3 = 0;
        var espessura = parseFloat($("#txtespessura").val()) / 1000; // Converte a espessura para metros

        if (isNaN(espessura) || espessura <= 0) {
            alert("Erro: Espessura inválida.");
            return;
        }

        // Seleciona todos os elementos com a classe "peça"
        document.querySelectorAll(".peça").forEach(function (retangulo) {
            // Obtém as dimensões do retângulo a partir do texto dentro do <span>
            var texto = retangulo.innerText.trim();
            var dimensoes = texto.split("X"); // Divide o texto "larguraXcomprimento"

            if (dimensoes.length === 2) {
                var largura = parseFloat(dimensoes[0]) / 1000; // Converte para metros
                var comprimento = parseFloat(dimensoes[1]) / 1000; // Converte para metros

                if (!isNaN(largura) && !isNaN(comprimento)) {
                    totalM3 += largura * comprimento * espessura; // Soma o volume do retângulo
                }
            }
        });

        // Atualiza o campo de entrada com o valor total calculado
        $("#txtm3peças").val(totalM3.toFixed(4)); // Armazena o valor com 6 casas decimais para maior precisão
    }




    function excluirRetangulo(numero) {
        if (!numero) {
            console.warn("Número inválido para exclusão!");
            return;
        }

        var classeExcluir = "R-" + numero;
        var retangulos = document.querySelectorAll("." + classeExcluir);

        if (retangulos.length === 0) {
            console.warn("Nenhum retângulo encontrado com a classe: " + classeExcluir);
            return;
        }

        console.log("Excluindo retângulos da classe: " + classeExcluir);

        retangulos.forEach(function (retangulo) {
            retangulo.remove();
        });
    }




