            medida_X1 = medida_X;
            medida_Y1 = medida_Y;


            Calculo_3();//realiza calculo 3
            XF = X;
            YF = Y;
            $("#txtsobra1").val((comprimentochapa - (XF - 57)) + "X" + (largurachapa - (YF - 57)));
            X1 = X;
            Y1 = Y;

