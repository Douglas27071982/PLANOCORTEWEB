    //desenha chapa
    function Chapa() {

        var Comprimento = $("#txtcomprimento").val();
        var Largura = $("#txtlargura").val();
        var Espessura = $("#txtespessura").val();

        // Validar campos
        if (Comprimento === "" || Largura === "" || Espessura === "") {

            alert("É necessário informar as medidas da chapa.");

            $("#txtcomprimento").focus();

            return;
        }

        habilitarCampos();

        let alvo = document.getElementById("div2");
        alvo.innerText = "";

        var div = document.createElement("DIV");

        div.style.width = $("#txtcomprimento").val() * 0.29 + "px";
        div.style.height = $("#txtlargura").val() * 0.29 + "px";
        div.style.background = "DarkGray";
        div.style.borderColor = "Black";
        div.classList.add("chapa");

        document.getElementById("div2").appendChild(div);

        div.id = "chapa";

        comprimentochapa = parseFloat($("#txtcomprimento").val()) || 0;
        largurachapa = parseFloat($("#txtlargura").val()) || 0;

        $("#txtm2chapa").val(
            (
                ($("#txtcomprimento").val() / 1000) *
                ($("#txtlargura").val() / 1000)
            ).toFixed(2)
        );

        var Ref1 = $("#txtretalhoh").val();
        var Ref2 = $("#txtretalhov").val();
        var Serra = $("#txtserra").val();

        retalhoh = ($("#txtretalhoh").val() * 1);
        retalhov = ($("#txtretalhov").val() * 1);
    }


