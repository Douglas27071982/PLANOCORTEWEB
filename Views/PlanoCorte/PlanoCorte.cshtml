    function Calculo1() {
        X = 57 + retalhov;//define ponto inicial eixo x
        Y = 57 + retalhoh;//define ponto inicial eixo y

        grupoRetangulo = 1;
        var tipo = parseInt($("#txttipo1").val()); // tipo 3 = corte longitudinal ou 4 = corte transversal

        //se o corte for longitudinal
        if (tipo === 3) {


            medida_Y = parseInt($("#txtcomprimento1").val()) || 0;//pega a medida informada no input medida 1
            medida_X = comprimentochapa - (parseInt($("#txtretalhov").val()) * 2); //pega o comprimento da chapa - retalhos
