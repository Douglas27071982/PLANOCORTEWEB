    function Calculo_3() {

        var grupoClasse = "R-" + grupoRetangulo; // Cria um identificador único para o grupo de retângulos



        // Verifica se o elemento "chapa" existe antes de tentar adicionar os retângulos
        var chapa = document.getElementById("chapa");
        if (!chapa) {
            alert("Erro: O elemento 'chapa' não foi encontrado no documento.");
            return;
        }

        // Loop para gerar os retângulos
        for (var i = 0; i < qtde_1; i++) {
            var p = document.createElement("p");

            // Configura as dimensões do retângulo
            p.style.width = (medida_X * 0.29) + "px";
            p.style.height = (medida_Y * 0.29) + "px";
            p.style.background = "white";
            p.style.color = "black";
            p.style.position = "absolute";
            p.style.top = (Y * 0.29) + "px";
            p.style.left = (X * 0.29) + "px";
            p.style.display = "flex";
            p.style.alignItems = "center";
            p.style.justifyContent = "center";
            p.style.fontSize = "16px";
            p.style.border = "1px solid black"; // Apenas para visualização

            // Definição de classes
            p.className = "peça " + grupoClasse; // Garante que cada peça tenha a classe correta

            // Criar um elemento <span> para o texto
            var span = document.createElement("span");
            span.innerHTML = medida_Y + "X" + medida_X;

            // Rotaciona o texto caso a altura seja maior que a largura
            if (medida_Y > medida_X) {
                span.style.transform = "rotate(90deg)";
                span.style.display = "inline-block"; // Necessário para a rotação correta
            }

            p.appendChild(span); // Adiciona o span ao retângulo
            p.id = "peça-" + grupoRetangulo + "-" + i; // Define um ID único para cada peça
            chapa.appendChild(p); // Adiciona o retângulo ao elemento "chapa"

            // Atualiza Y para o próximo retângulo
            Y += medida_Y + serra;

        }

        X += medida_X + serra;

        grupoRetangulo++; // Incrementa o número do grupo para os próximos retângulos
        ContarPecas()
        CalcularAreaTotal()
        CalcularVolumeTotal()
        aproveitamento = $("#txtm2peças").val() / $("#txtm2chapa").val() * 100;

        $("#txtaproveitamento").val(aproveitamento.toFixed(2));
    }



