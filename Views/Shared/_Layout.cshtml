<!DOCTYPE html>
<html lang="pt-br">



<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="">
    <meta name="author" content="">
    <title>Otimizador Plano de Corte - MENU</title>
    <!-- Custom fonts for this template-->

    <link href="~/css/style_menu1.css" rel="stylesheet" />
    <a href="~/lib/bootstrap/dist/css/bootstrap.min.css.map">~/lib/bootstrap/dist/css/bootstrap.min.css.map</a>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/responsive2.css" />
    <link rel="stylesheet" href="~/font-awesome/css/font-awesome.min.css" />
    <link rel="stylesheet" href="~/css/sweetalert2.css" />







    <style>
        #sidebar {
            min-width: 250px;
            max-width: 250px;
            background: #222E3C;
            color: #222E3C;
            transition: all 0.1s;
            position: relative;
            z-index: 11;
            box-shadow: 0 0 3px 0px rgba(20,233, 1, 0.4);
            float: left;
            width: 100%;
            position: fixed;
            height: 100%;
            overflow: auto;
        }

    </style>



</head>
<body>





    <div class="full_container">
        <div class="inner_container">
            <!-- Sidebar  -->
            <nav id="sidebar">
                <div class="barra_lateral_blog ">
                    <div class="cabeçalho">
                        <div class="logo_responsivo">
                            <a href="@Url.Action("Index", "Home")"><img class="logo_icone imagen_responsive " src="~/Imagens/IMG_RES.png" alt="#" /></a>

                        </div>
                    </div>
                    <div class="barra_lateral_logo">
                        <div class="icones_config"></div>
                        <div class="logo">
                            <div><img src="~/Imagens/LOGO.png" style="width: 100%;height: 70px; margin-top:10px" alt="#" /></div>



                        </div>
                    </div>
                </div>
                <div>
                    <div class="barra_lateral_menu">

                        <ul class="lista_menu componentes">
                            <li><a href="@Url.Action("Index", "Home")" style="font-size: 17px;"><i class="fa fa-tasks fa-2x green_color"></i><span>Menu</span></a></li>

                        </ul>
                        <ul class="lista_menu componentes">











                            <li>
                                <a href="#element" data-toggle="collapse" aria-expanded="false" class="dropdown-toggle" style=" font-size: 17px;"><i class="fa fa-cubes red_color"></i> <span>Planos de Corte</span></a>
                                <ul class="collapse lista_menu" id="element">
                                    <li><a href="@Url.Action("PlanoCorte", "PlanoCorte")"> <span style=" font-size: 17px;">Simulador Plano de Corte</span></a></li>
                                   

                                </ul>
                            </li>
                           
                          
                           

                            
                            

                           

                           

                           


                           

                        </ul>
                    </div>
                </div>
            </nav>

            <div id="content">

                <div class="topbar ">
                    <nav class="navbar navbar-expand-lg navbar-light ">
                        <div class="full">
                            <button type="button" id="sidebarCollapse" class="sidebar_toggle"><i class="fa fa-bars"></i></button>
                            <div class="logo_responsivo">
                                <!--aqui da pra colocar o nome do menu-->
                            </div>
                            <div class="right_topbar">
                                <div class="icon_info">
                                    <ul>
                                        <li><a href="#"><i class="fa fa-bell-o"></i><span class="badge">2</span></a></li>
                                        <li><a href="#"><i class="fa fa-question-circle"></i></a></li>
                                        <li><a href="#"><i class="fa fa-envelope-o"></i><span class="badge">3</span></a></li>
                                    </ul>
                                    <ul class="user_profile_dd">
                                        <li>

                                            <a class="dropdown-toggle fa fa-user azul_color" data-toggle="dropdown"><span class="name_user azul_color" style="font-size: 20px;">@ViewData["Nome"] -  @ViewData["Tipo"] </span></a>
                                            <div class="dropdown-menu">

                                                <a class="dropdown-item" href="settings.html">Settings</a>

                                                <a class="dropdown-item" href="@Url.Action("Login", "Login")"><span>Log Out</span> <i class="fa fa-sign-out"></i></a>
                                            </div>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </nav>
                </div>

                <div class="midde_cont">
                    <div class="container-fluid ">
                        <p>

                        </p>


                        @RenderBody()





                    </div>


                </div>


            </div>



            <!-- end model popup -->
        </div>
        <footer class="sticky-footer bg-white">
            <div class="container my-auto">
                <div class="copyright text-center my-auto azul_color">
                    <span>Copyright &copy; Your Website 2023</span>
                </div>
            </div>
        </footer>

        <!-- jQuery -->
        <script src="~/js/jquery.min.js"></script>

        <script src="~/js/bootstrap.min.js"></script>

        <script src="~/js/bootstrap-select.js"></script>
        <script src="~/js/custon_1.js"></script>
        <script src="~/js/sweetalert.min.js"></script>
        <script src="~/js/sweetalert2.js"></script>
        @RenderSection("scripts", required: false)






    </div>





    <script type="text/javascript">






    </script>


</body>
</html>